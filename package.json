{
  "name": "vscode-chezmoi",
  "displayName": "Chezmoi",
  "description": "Syntax highlighting for chezmoi templated files (.tmpl, .sh.tmpl, .zsh.tmpl, .ps1.tmpl, .py.tmpl, .toml.tmpl, .yaml.tmpl, .json.tmpl, .ini.tmpl): base language + Go Template injection",
  "version": "0.2.0",
  "publisher": "applejxd",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "chezmoi",
    "template",
    "go-template",
    "syntax-highlighting",
    "shell",
    "powershell",
    "python",
    "toml",
    "yaml",
    "json",
    "ini"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/github/actions/workflow/status/applejxd/vscode-chezmoi/ci.yml?label=CI",
      "href": "https://github.com/applejxd/vscode-chezmoi/actions",
      "description": "CI Status"
    }
  ],
  "preview": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/applejxd/vscode-chezmoi.git"
  },
  "bugs": {
    "url": "https://github.com/applejxd/vscode-chezmoi/issues"
  },
  "homepage": "https://github.com/applejxd/vscode-chezmoi#readme",
  "activationEvents": [],
  "main": "./out/extension.js",
  "extensionPack": [
    "jinliming2.vscode-go-template"
  ],
  "contributes": {
    "languages": [
      {
        "id": "chezmoi-tmpl",
        "aliases": ["Chezmoi Template", "chezmoi-tmpl"],
        "extensions": [".tmpl"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "chezmoi-sh-tmpl",
        "aliases": ["Chezmoi Shell Template", "chezmoi-sh-tmpl"],
        "extensions": [".sh.tmpl"],
        "configuration": "./language-configuration-shell.json"
      },
      {
        "id": "chezmoi-zsh-tmpl",
        "aliases": ["Chezmoi Zsh Template", "chezmoi-zsh-tmpl"],
        "extensions": [".zsh.tmpl"],
        "configuration": "./language-configuration-shell.json"
      },
      {
        "id": "chezmoi-ps1-tmpl",
        "aliases": ["Chezmoi PowerShell Template", "chezmoi-ps1-tmpl"],
        "extensions": [".ps1.tmpl"],
        "configuration": "./language-configuration-powershell.json"
      },
      {
        "id": "chezmoi-py-tmpl",
        "aliases": ["Chezmoi Python Template", "chezmoi-py-tmpl"],
        "extensions": [".py.tmpl"],
        "configuration": "./language-configuration-python.json"
      },
      {
        "id": "chezmoi-toml-tmpl",
        "aliases": ["Chezmoi TOML Template", "chezmoi-toml-tmpl"],
        "extensions": [".toml.tmpl"],
        "configuration": "./language-configuration-toml.json"
      },
      {
        "id": "chezmoi-yaml-tmpl",
        "aliases": ["Chezmoi YAML Template", "chezmoi-yaml-tmpl"],
        "extensions": [".yaml.tmpl", ".yml.tmpl"],
        "configuration": "./language-configuration-yaml.json"
      },
      {
        "id": "chezmoi-json-tmpl",
        "aliases": ["Chezmoi JSON Template", "chezmoi-json-tmpl"],
        "extensions": [".json.tmpl"],
        "configuration": "./language-configuration-json.json"
      },
      {
        "id": "chezmoi-ini-tmpl",
        "aliases": ["Chezmoi INI Template", "chezmoi-ini-tmpl"],
        "extensions": [".ini.tmpl"],
        "configuration": "./language-configuration-ini.json"
      }
    ],
    "grammars": [
      {
        "language": "chezmoi-tmpl",
        "scopeName": "text.plain.chezmoi",
        "path": "./syntaxes/chezmoi-tmpl.tmLanguage.json"
      },
      {
        "language": "chezmoi-sh-tmpl",
        "scopeName": "source.shell.chezmoi",
        "path": "./syntaxes/chezmoi-sh-tmpl.tmLanguage.json"
      },
      {
        "language": "chezmoi-zsh-tmpl",
        "scopeName": "source.zsh.chezmoi",
        "path": "./syntaxes/chezmoi-zsh-tmpl.tmLanguage.json"
      },
      {
        "language": "chezmoi-ps1-tmpl",
        "scopeName": "source.powershell.chezmoi",
        "path": "./syntaxes/chezmoi-ps1-tmpl.tmLanguage.json"
      },
      {
        "language": "chezmoi-py-tmpl",
        "scopeName": "source.python.chezmoi",
        "path": "./syntaxes/chezmoi-py-tmpl.tmLanguage.json"
      },
      {
        "language": "chezmoi-toml-tmpl",
        "scopeName": "source.toml.chezmoi",
        "path": "./syntaxes/chezmoi-toml-tmpl.tmLanguage.json"
      },
      {
        "language": "chezmoi-yaml-tmpl",
        "scopeName": "source.yaml.chezmoi",
        "path": "./syntaxes/chezmoi-yaml-tmpl.tmLanguage.json"
      },
      {
        "language": "chezmoi-json-tmpl",
        "scopeName": "source.json.chezmoi",
        "path": "./syntaxes/chezmoi-json-tmpl.tmLanguage.json"
      },
      {
        "language": "chezmoi-ini-tmpl",
        "scopeName": "source.ini.chezmoi",
        "path": "./syntaxes/chezmoi-ini-tmpl.tmLanguage.json"
      },
      {
        "scopeName": "chezmoi.templating.injection",
        "path": "./syntaxes/chezmoi-templating.injection.tmLanguage.json",
        "injectTo": [
          "source.shell.chezmoi",
          "source.zsh.chezmoi",
          "source.powershell.chezmoi",
          "source.python.chezmoi",
          "source.toml.chezmoi",
          "source.yaml.chezmoi",
          "source.json.chezmoi",
          "source.ini.chezmoi",
          "text.plain.chezmoi"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.go-template": "go-template"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sinon": "^17.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.34.0",
    "markdownlint": "^0.40.0",
    "sinon": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
